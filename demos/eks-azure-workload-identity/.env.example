#!/usr/bin/env bash
# .env.example
#
# Environment variables for EKS + Azure Workload Identity Demo
#
# Copy this file to .env, update the values, and source it before running Terraform:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env
#   terraform init
#   terraform apply
#
# Alternatively, export the TF_VAR_* variables directly in your shell.

# ─────────────────────────────────────────────────────────────────────────────
# PREREQUISITES
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. AWS CLI must be authenticated. Verify with:
#      aws sts get-caller-identity
#
# 2. Azure CLI must be authenticated. Log in with:
#      az login
#
# 3. Create an Entra Application Registration and note:
#    - Application (client) ID: Used in TF_VAR_azure_client_id
#    - Object ID: Used in TF_VAR_azure_app_object_id
#    Command to get Object ID:
#      az ad app show --id <CLIENT_ID> --query id --output tsv

# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────

# AWS CLI profile to use for authentication (if you configured one with aws configure)
# Set this to the profile name you created, e.g., "terraform-profile"
# Leave empty to use the default profile or environment variables
export AWS_PROFILE="terraform-profile"

# AWS region where the EKS cluster will be deployed (default: us-east-1)
export TF_VAR_aws_region="us-east-1"

# Name of the EKS cluster
export TF_VAR_cluster_name="eks-azure-workload-identity-demo"

# Kubernetes version for the EKS cluster (default: 1.34)
export TF_VAR_cluster_version="1.34"

# Desired number of worker nodes (default: 2)
export TF_VAR_node_desired_size="2"

# Minimum number of worker nodes (default: 1)
export TF_VAR_node_min_size="1"

# Maximum number of worker nodes (default: 2)
export TF_VAR_node_max_size="3"

# ─────────────────────────────────────────────────────────────────────────────
# Azure / Entra Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Entra tenant ID (directory ID) where your app registration is located
# Get this from Azure Portal → Entra ID → Overview → Tenant ID
export TF_VAR_azure_tenant_id=<entra-tenant-id>

# Application (client) ID of your Entra Application Registration
# Get this from Azure Portal → App registrations → <Your App> → Application ID
# This is injected into the Kubernetes ServiceAccount annotation
export TF_VAR_azure_client_id=<entra-app-client-id>

# Object ID of your Entra Application Registration (required for federation setup)
# Get this from Azure Portal → App registrations → <Your App> → Overview → Object ID
# Or use: az ad app show --id <CLIENT_ID> --query id --output tsv
export TF_VAR_azure_app_object_id=<entra-app-object-id>

# ─────────────────────────────────────────────────────────────────────────────
# Demo Application Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Kubernetes namespace where the msal-go demo application will run (default: msal-go-demo)
export TF_VAR_app_namespace="msal-go-demo"

# Kubernetes ServiceAccount name for the demo application (default: msal-go-sa)
export TF_VAR_app_service_account_name="msal-go-sa"

# ─────────────────────────────────────────────────────────────────────────────
# Azure Key Vault Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Full URI of the Azure Key Vault that the demo workload will access
# Format: https://<vault-name>.vault.azure.net/
# Create with: az keyvault create -n <name> -g <rg> --location eastus
# Then grant permissions: az keyvault set-policy -n <name> --secret-permissions get --spn <client-id>
export TF_VAR_keyvault_url="https://<vault-name>.vault.azure.net/"

# Name of the secret in the Key Vault that the demo app will retrieve
# Create with: az keyvault secret set -n <secret-name> --vault-name <vault-name> --value "Hello!"
export TF_VAR_keyvault_secret_name="test-secret"

# ─────────────────────────────────────────────────────────────────────────────
# Federation Setup Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Automatically configure the Entra federated identity credential during Terraform apply
# Set to "true" to enable automatic setup (requires az CLI to be authenticated)
# Set to "false" to configure it manually afterward using the provided script
export TF_VAR_setup_federation="true"

# ─────────────────────────────────────────────────────────────────────────────
# Tagging
# ─────────────────────────────────────────────────────────────────────────────

# Tags are applied as JSON and can be complex. For simple overrides, you can set individual keys:
# export TF_VAR_tags='{"Project":"eks-azure-workload-identity-demo","Environment":"demo","ManagedBy":"terraform","Team":"platform"}'
# Or leave as default by not setting this variable.
